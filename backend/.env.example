# Anthropic — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# MongoDB Atlas connection string
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>

# Optional — MongoDB database name (defaults to "buffbites")
APP_NAME=buffbites

# Optional — port for uvicorn (defaults to 8000)
PORT=8000

# Optional but recommended — comma-separated list of allowed frontend origins for CORS.
# Leave unset to allow all origins (logs a warning). *.vercel.app is always allowed.
# Example: ALLOWED_ORIGINS=https://buffbites.app,http://localhost:3000
ALLOWED_ORIGINS=

# Firebase service account credentials (production / Docker)
# Paste the full contents of serviceAccountKey.json as a single-line JSON string.
# Generate at: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Locally you can leave this unset and use serviceAccountKey.json instead.
FIREBASE_SERVICE_ACCOUNT_JSON=
