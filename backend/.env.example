# Anthropic — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# MongoDB Atlas connection string
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>

# Optional — MongoDB database name (defaults to "combos")
APP_NAME=combos

# Optional — port for uvicorn (defaults to 3001 in startup command)
PORT=3001
